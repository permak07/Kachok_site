# Основное приложение (FastAPI) использует эту переменную
DATABASE_URL=postgresql+asyncpg://user:password@host:port/database

# Для Alembic (миграции) используются отдельные переменные
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=database

# JWT-настройки
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60